{
	"name": "r2-uploads/r2-uploads",
	"description": "WordPress plugin to store uploads on Cloudflare R2",
	"homepage": "https://github.com/r2-uploads/r2-uploads",
	"keywords": [
		"wordpress"
	],
	"license": "GPL-2.0-or-later",
	"autoload": {
		"classmap": [ "inc/" ]
	},
	"authors": [
		{
			"name": "Human Made",
			"homepage": "https://humanmade.com/"
		}
	],
	"support": {
			"issues": "https://github.com/r2-uploads/r2-uploads/issues",
			"source": "https://github.com/r2-uploads/r2-uploads"
	},
	"type": "wordpress-plugin",
	"require": {
		"php": ">=8.0",
		"composer/installers": "~1.0 || ^2.0",
		"aws/aws-sdk-php": "^3.366"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"pcov/clobber": "^2.0",
		"vimeo/psalm": "^5.0",
		"humanmade/psalm-plugin-wordpress": "^3.1",
		"yoast/phpunit-polyfills": "^4.0"
	},
	"scripts": {
		"test": "./tests/run-tests.sh",
		"check-types": "./vendor/bin/psalm"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
