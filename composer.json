{
	"name": "r2-uploads/r2-uploads",
	"description": "WordPress plugin to store uploads on Cloudflare R2",
	"homepage": "https://github.com/carnaval-studio/r2-uploads",
	"keywords": [
		"wordpress"
	],
	"license": "GPL-2.0-or-later",
	"autoload": {
		"classmap": [ "inc/" ]
	},
	"authors": [
		{
			"name": "Carnaval Studio",
			"homepage": "https://github.com/carnaval-studio"
		}
	],
	"support": {
			"issues": "https://github.com/carnaval-studio/r2-uploads/issues",
			"source": "https://github.com/carnaval-studio/r2-uploads"
	},
	"type": "wordpress-plugin",
	"require": {
		"php": ">=8.3",
		"composer/installers": "~1.0 || ^2.0",
		"aws/aws-sdk-php": "^3.384"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"wp-phpunit/wp-phpunit": "^6.7",
		"yoast/phpunit-polyfills": "^4.0"
	},
	"scripts": {
		"test": "./tests/run-tests.sh",
		"test:local": "./tests/run-tests-local.sh"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		},
		"platform": {
			"php": "8.3.0"
		}
	}
}
