<phpunit
	bootstrap="tests/bootstrap.php"
	backupGlobals="false"
	colors="true"
	>
	<testsuites>
			<!-- Default test suite to run all tests -->
			<testsuite name="R2_Uploads">
					<directory prefix="test-" suffix=".php">tests</directory>
			</testsuite>
	</testsuites>
	<coverage>
		<include>
			<directory suffix=".php">./inc</directory>
			<file>./r2-uploads.php</file>
		</include>
		<exclude>
			<directory suffix=".php">./lib</directory>
			<file>./inc/class-wp-cli-command.php</file>
		</exclude>
	</coverage>
</phpunit>
